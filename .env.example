# Maple Quotations — environment

# Its OWN Postgres database (separate from maple-suite).
DATABASE_URL="postgresql://postgres:maple@localhost:5544/maple_quotations?schema=public"

# Signs/verifies the mt_session JWT. Generate: openssl rand -hex 32
# Keep IDENTICAL to the suite's AUTH_SECRET only if you want shared SSO across
# *.maplefurnishers.com; otherwise any value works for standalone login.
AUTH_SECRET="dev-insecure-secret-change-me"

# Optional. Where the auth gate redirects when signed out. Unset => local /login.
# Point at a shared SSO login when deployed on the suite domain.
# LOGIN_URL="https://admin.maplefurnishers.com/login"

# Optional. In production set to ".maplefurnishers.com" so the session cookie is
# shared across tool subdomains. Leave unset for local/standalone.
# COOKIE_DOMAIN=".maplefurnishers.com"

# Optional. Feature flags (Flipt). Unset => everything enabled (fail-open).
# FLIPT_URL="http://localhost:8080"
