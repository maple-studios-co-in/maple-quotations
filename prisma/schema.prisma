// Maple Quotations — its OWN database (separate from maple-suite).
// Only the models this tool needs. Cross-module links use a stable global id
// (cuid) + a denormalized snapshot, never a live cross-DB join. See ARCHITECTURE.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  domain       String?  @unique
  brandName    String   @default("Maple Furnishers")
  logoUrl      String?
  bannerUrl    String?
  primaryColor String?
  addressLine1 String?
  addressLine2 String?
  phone        String?
  email        String?
  gstin        String?
  website      String?
  tagline      String?
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  users        User[]
  clients      Client[]
  quotations   Quotation[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("sales")
  perms        String[] @default([])
  createdAt    DateTime @default(now())
}

// Local client cache. The system of record for clients is the CRM module; here we
// keep a lightweight copy keyed by the same global id so quotations can resolve and
// display a client without calling out. Kept in sync via API/events later.
model Client {
  id         String      @id @default(cuid())
  tenantId   String?
  tenant     Tenant?     @relation(fields: [tenantId], references: [id])
  name       String
  company    String?
  gstin      String?
  phone      String?
  email      String?
  address    String?
  status     String      @default("active")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  quotations Quotation[]
}

model Quotation {
  id             String   @id @default(cuid())
  tenantId       String?
  tenant         Tenant?  @relation(fields: [tenantId], references: [id])
  number         String   @unique
  clientId       String?
  client         Client?  @relation(fields: [clientId], references: [id])
  clientSnapshot Json?    // frozen client copy at quote time (ecosystem seam)
  data           Json
  total          Float    @default(0)
  status         String   @default("draft")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Outbox for future inter-module events (e.g. quotation.accepted -> orders module).
// No consumer yet; the seam exists so wiring the ecosystem later is cheap.
model OutboxEvent {
  id        String   @id @default(cuid())
  tenantId  String?
  type      String
  payload   Json
  status    String   @default("pending") // pending | sent | failed
  createdAt DateTime @default(now())
}

// Runtime app configuration editable from the Settings page (admin only).
// Secret values (API keys) are stored AES-256-GCM encrypted with a key derived
// from AUTH_SECRET; non-secrets are plain text.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Stored images: brand assets (logo, banner) and the product photo gallery.
// Bytes live in Postgres for now; move to object storage if volume demands.
model Asset {
  id        String    @id @default(cuid())
  tenantId  String?
  kind      String // logo | banner | product
  name      String
  mime      String
  data      Bytes
  createdAt DateTime  @default(now())
  products  Product[]
}

// The product library: every AI-imported or manually saved item, addressable
// by a stable code (MF-P-0001) and reusable across quotes.
model Product {
  id            String   @id @default(cuid())
  tenantId      String?
  code          String   @unique
  name          String
  category      String?
  specification String?
  material      String?
  unitType      String   @default("nos")
  defaultRate   Float?
  imageAssetId  String?
  image         Asset?   @relation(fields: [imageAssetId], references: [id])
  source        String   @default("manual") // manual | ai-import
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Monotonic counters (product codes etc.)
model Counter {
  key   String @id
  value Int    @default(0)
}
